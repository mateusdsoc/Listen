{
  "info": {
    "name": "Listen API - Sprints 1 e 2",
    "description": "Coleção de testes do backend Listen.\n\nFluxo completo: cadastro → login → criar sessão → aceitar → iniciar → concluir.\n\nExecute os requests na ordem de cima para baixo. Os IDs e tokens são salvos automaticamente entre requests.\n\nSprint 2 — eventos publicados no RabbitMQ durante o fluxo:\n  • POST /sessoes              → emite sessao.criada\n  • PATCH /sessoes/{id}/status → emite sessao.aceita (transição p/ aceita)\n                                ou sessao.encerrada (transição p/ concluida/cancelada)\n\nAcompanhe pelo container 'listen-consumer' (docker logs -f) ou pela UI do RabbitMQ em http://localhost:15672 (guest/guest).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "solicitanteId", "value": "" },
    { "key": "ouvinteId", "value": "" },
    { "key": "sessaoId", "value": "" },
    { "key": "tokenSolicitante", "value": "" },
    { "key": "tokenOuvinte", "value": "" }
  ],
  "item": [
    {
      "name": "0. Health Check",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "1. Cadastrar solicitante",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "if (json.id) pm.collectionVariables.set('solicitanteId', json.id);",
              "pm.test('Retorna id e email', () => {",
              "  pm.expect(json).to.have.property('id');",
              "  pm.expect(json).to.have.property('email');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"primeiro_nome\": \"Ana\",\n  \"email\": \"ana@example.com\",\n  \"senha\": \"senha123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/solicitantes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "solicitantes"]
        }
      }
    },
    {
      "name": "1b. Cadastrar solicitante (email duplicado - deve falhar)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"primeiro_nome\": \"Ana Duplicada\",\n  \"email\": \"ana@example.com\",\n  \"senha\": \"outrasenha\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/solicitantes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "solicitantes"]
        }
      }
    },
    {
      "name": "2. Cadastrar ouvinte",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "if (json.id) pm.collectionVariables.set('ouvinteId', json.id);",
              "pm.test('Retorna instituicao e periodo', () => {",
              "  pm.expect(json).to.have.property('instituicao');",
              "  pm.expect(json).to.have.property('periodo');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"primeiro_nome\": \"Bruno\",\n  \"email\": \"bruno@example.com\",\n  \"senha\": \"senha123\",\n  \"instituicao\": \"PUC Minas\",\n  \"periodo\": 5,\n  \"disponivel\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/ouvintes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "ouvintes"]
        }
      }
    },
    {
      "name": "2b. Cadastrar ouvinte com email de solicitante (deve falhar)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 409 - email já usado como solicitante', () => pm.response.to.have.status(409));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"primeiro_nome\": \"Ana Tentativa Ouvinte\",\n  \"email\": \"ana@example.com\",\n  \"senha\": \"senha123\",\n  \"instituicao\": \"PUC Minas\",\n  \"periodo\": 3,\n  \"disponivel\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/ouvintes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "ouvintes"]
        }
      }
    },
    {
      "name": "3. Login solicitante",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "if (json.access_token) pm.collectionVariables.set('tokenSolicitante', json.access_token);",
              "pm.test('Retorna token e role', () => {",
              "  pm.expect(json).to.have.property('access_token');",
              "  pm.expect(json.role).to.eql('solicitante');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"ana@example.com\",\n  \"senha\": \"senha123\",\n  \"role\": \"solicitante\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "login"]
        }
      }
    },
    {
      "name": "3b. Login ouvinte",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "if (json.access_token) pm.collectionVariables.set('tokenOuvinte', json.access_token);",
              "pm.test('Retorna token e role ouvinte', () => {",
              "  pm.expect(json).to.have.property('access_token');",
              "  pm.expect(json.role).to.eql('ouvinte');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"bruno@example.com\",\n  \"senha\": \"senha123\",\n  \"role\": \"ouvinte\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "login"]
        }
      }
    },
    {
      "name": "3c. Login com senha errada (deve falhar)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"ana@example.com\",\n  \"senha\": \"senhaERRADA\",\n  \"role\": \"solicitante\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "login"]
        }
      }
    },
    {
      "name": "4. Criar sessão (com token solicitante)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "if (json.id) pm.collectionVariables.set('sessaoId', json.id);",
              "pm.test('Status pendente e solicitante_id correto', () => {",
              "  pm.expect(json.status).to.eql('pendente');",
              "  pm.expect(json.solicitante_id).to.eql(pm.collectionVariables.get('solicitanteId'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{tokenSolicitante}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"descricao\": \"Estou ansioso com as provas e gostaria de conversar com alguém.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/sessoes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "sessoes"]
        }
      }
    },
    {
      "name": "4b. Criar sessão sem token (deve falhar 401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 - sem autenticação', () => pm.response.to.have.status(401));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"descricao\": \"Tentativa sem token.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/sessoes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "sessoes"]
        }
      }
    },
    {
      "name": "5. Listar sessões pendentes (token ouvinte)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Retorna array', () => {",
              "  pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tokenOuvinte}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/sessoes/pendentes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "sessoes", "pendentes"]
        }
      }
    },
    {
      "name": "6. Consultar sessão por ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('ID correto', () => {",
              "  pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('sessaoId'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tokenSolicitante}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/sessoes/{{sessaoId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "sessoes", "{{sessaoId}}"]
        }
      }
    },
    {
      "name": "7. Aceitar sessão (ouvinte)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Status aceita', () => {",
              "  pm.expect(pm.response.json().status).to.eql('aceita');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{tokenOuvinte}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"aceita\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/sessoes/{{sessaoId}}/status",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "sessoes", "{{sessaoId}}", "status"]
        }
      }
    },
    {
      "name": "8. Iniciar sessão (em_andamento)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Status em_andamento', () => {",
              "  pm.expect(pm.response.json().status).to.eql('em_andamento');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{tokenOuvinte}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"em_andamento\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/sessoes/{{sessaoId}}/status",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "sessoes", "{{sessaoId}}", "status"]
        }
      }
    },
    {
      "name": "9. Concluir sessão",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Status concluida', () => {",
              "  pm.expect(pm.response.json().status).to.eql('concluida');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{tokenOuvinte}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"concluida\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/sessoes/{{sessaoId}}/status",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "sessoes", "{{sessaoId}}", "status"]
        }
      }
    }
  ]
}
